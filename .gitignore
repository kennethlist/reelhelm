# ── Build artifacts ────────────────────────────────────────────────
# Gradle / Android build output
**/build/
.gradle/
.kotlin/
.cxx/
.externalNativeBuild/
/captures/
*.apk
*.aab
*.ap_
*.dex
*.class

# Native cross-compile outputs (regenerated by scripts/build-pjsip.sh)
android/scripts/openssl-build/

# Vendored source clones pulled by the build script (huge, reproducible)
android/scripts/openssl/
android/scripts/pjproject/

# Generated pjsua2 payload — SWIG Java bindings + compiled .so.
# NOT hand-written: regenerate with `android/scripts/build-pjsip.sh`
# (see android/pjsua2/README.md). The module's AndroidManifest.xml,
# README.md and build.gradle.kts above these dirs stay tracked.
android/pjsua2/src/main/java/org/pjsip/pjsua2/
android/pjsua2/src/main/jniLibs/

